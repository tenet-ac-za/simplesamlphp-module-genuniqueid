{
    "name": "safire-ac-za/simplesamlphp-module-genuniqueid",
    "description": "SimpleSAMLphp module to generate an eduPersonUniqueId attribute from various LDAP implementations' objectGUID",
    "type": "simplesamlphp-module",
    "keywords": ["simplesamlphp", "genuniqueid", "eduPersonUniqueId", "LDAP", "ObjectGUID"],
    "license": "MIT",
    "authors": [
        {
            "name": "Guy Halse",
            "homepage": "http://orcid.org/0000-0002-9388-8592"
        }
    ],
    "config": {
        "preferred-install": {
            "simplesamlphp/simplesamlphp": "source",
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true,
            "simplesamlphp/composer-module-installer": true,
            "simplesamlphp/composer-xmlprovider-installer": true
        }
    },
    "require": {
        "php": "^8.1",
        "simplesamlphp/assert": "^0.8.0 || ^1.0.0"
    },
    "require-dev": {
        "simplesamlphp/simplesamlphp": ">=2.0.0 <2.6.0",
        "simplesamlphp/simplesamlphp-test-framework": "~1.9.2"
    },

    "autoload": {
        "psr-4": {
            "SimpleSAML\\Module\\genuniqueid\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SimpleSAML\\Test\\Utils\\": "vendor/simplesamlphp/simplesamlphp/tests/Utils"
        }
    },
    "support": {
        "issues": "https://github.com/tenet-ac-za/simplesamlphp-module-genuniqueid/issues",
        "source": "https://github.com/tenet-ac-za/simplesamlphp-module-genuniqueid"
    }
}
